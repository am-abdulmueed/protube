<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg_rounded"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/dialog_icon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ytpro" />

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Protube Reward"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dialog_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:alpha="0.8"
        android:gravity="center"
        android:text="Enjoy an ad-free experience. Just watch one short ad to unlock unlimited playback without interruptions."
        android:textColor="@color/white"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_watch_ad"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/button_bg_gradient"
        android:text="WATCH AD NOW"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:elevation="4dp" />

    <TextView
        android:id="@+id/btn_later"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:text="Not now"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
